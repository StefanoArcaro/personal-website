---
interface Props {
  current?: "home" | "work" | "contact";
}
const { current } = Astro.props;
---

<nav class="nav" aria-label="Main navigation">
  <a class="logo" href="/" aria-label="Stefano Arcaro — home" aria-current={current === "home" ? "page" : undefined}>SA</a>
  <ul role="list">
    <li>
      <a
        href="/work"
        class:list={[{ active: current === "work" }]}
        aria-current={current === "work" ? "page" : undefined}
      >work</a>
    </li>
    <li>
      <a
        href="/contact"
        class:list={[{ active: current === "contact" }]}
        aria-current={current === "contact" ? "page" : undefined}
      >contact</a>
    </li>
  </ul>
  <a class="recruiters" href="/contact">for recruiters →</a>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.12em;
    color: var(--text);
    padding: 6px 9px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }
  .logo:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-3);
  }
  ul a {
    position: relative;
    padding: 2px 0;
    color: var(--muted);
    transition: color var(--dur-fast) var(--ease);
  }
  ul a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -2px;
    height: 1px;
    background: var(--accent);
    transition: right var(--dur) var(--ease);
  }
  ul a:hover,
  ul a.active {
    color: var(--text);
  }
  ul a:hover::after,
  ul a.active::after {
    right: 0;
  }

  .recruiters {
    margin-left: auto;
    font-size: var(--fs-xs);
    color: var(--muted);
    font-style: italic;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    transition: color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .recruiters:hover {
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 10%, transparent);
  }
</style>
