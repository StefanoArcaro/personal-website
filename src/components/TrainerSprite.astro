---
interface Props {
  size?: number;
  class?: string;
}
const { size = 40, class: className } = Astro.props;
const width = size;
const height = Math.round((size / 8) * 10);
---

<svg
  class={className}
  width={width}
  height={height}
  viewBox="0 0 8 10"
  shape-rendering="crispEdges"
  aria-hidden="true"
>
  <rect x="2" y="0" width="4" height="1" fill="var(--sprite-outline)"></rect>
  <rect x="1" y="1" width="6" height="1" fill="var(--sprite-outline)"></rect>
  <rect x="0" y="2" width="8" height="1" fill="var(--sprite-outline)"></rect>
  <rect x="0" y="3" width="1" height="4" fill="var(--sprite-outline)"></rect>
  <rect x="7" y="3" width="1" height="4" fill="var(--sprite-outline)"></rect>
  <rect x="1" y="3" width="6" height="4" fill="var(--sprite-skin)"></rect>
  <rect x="2" y="4" width="1" height="1" fill="var(--sprite-outline)"></rect>
  <rect x="5" y="4" width="1" height="1" fill="var(--sprite-outline)"></rect>
  <rect x="3" y="6" width="2" height="1" fill="var(--sprite-outline)"></rect>
  <rect x="1" y="7" width="6" height="1" fill="var(--sprite-outline)"></rect>
  <rect x="2" y="8" width="4" height="2" fill="var(--sprite-shirt)"></rect>
</svg>
