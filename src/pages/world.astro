---
import Base from "../layouts/Base.astro";
import OverworldGame from "../components/OverworldGame";
---

<Base
  title="The World — Stefano Arcaro"
  description="A Pokémon-style overworld. Use arrow keys to explore."
>
  <main id="main-content" class="world">
    <a href="/" class="back">← back to the real world</a>
    <div class="game-wrapper">
      <OverworldGame client:only="react" />
    </div>
  </main>
</Base>

<style>
  .world {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-5) var(--space-4);
    background: var(--bg);
    position: relative;
  }

  .back {
    position: fixed;
    top: var(--space-3);
    left: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.05em;
    color: var(--muted);
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    transition:
      color var(--dur-fast) var(--ease),
      background var(--dur-fast) var(--ease);
    z-index: 10;
  }

  .back:hover {
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 10%, transparent);
  }

  .game-wrapper {
    width: 100%;
    max-width: 672px;
    padding-top: var(--space-5);
  }

  .game-wrapper :global(canvas) {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    display: block;
    width: 100% !important;
    height: 100% !important;
  }
</style>
